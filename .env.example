# Server Configuration
PORT=3000
NODE_ENV=development

# Security - ONLY set to true in development for testing
# NEVER enable in production
ALLOW_INSECURE_WEBHOOKS=false

# Shopify Configuration
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# LAAR Courier Configuration
LAAR_BASE_URL=https://api.laarcourier.com:9727
LAAR_USERNAME=your_laar_username
LAAR_PASSWORD=your_laar_password
# Token expiration in minutes (default 55, LAAR tokens typically last 60 min)
LAAR_TOKEN_EXPIRATION_MINUTES=55

# Default Codes
# City code for origin (default origin location)
DEFAULT_ORIGIN_CITY_CODE=201001001001
# LAAR service type code
DEFAULT_SERVICE_CODE=201202002002013

# Origin Address (your warehouse/store)
ORIGIN_IDENTIFICACION=0999999999
ORIGIN_NOMBRE=Mi Tienda
ORIGIN_DIRECCION=Av. Principal 123
ORIGIN_REFERENCIA=Junto al parque central
ORIGIN_CIUDAD=201001001001
ORIGIN_TELEFONO=0999999999
ORIGIN_CELULAR=0999999999
ORIGIN_CORREO=tienda@example.com
